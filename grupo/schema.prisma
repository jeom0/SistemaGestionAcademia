// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                BigInt      @id @default(autoincrement())
  name              String
  email             String      @unique
  password          String
  role              String      // root, administrator, collaborator
  status            String      @default("activo") // activo, inactivo
  avatar            String?     // path to profile image
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updated_at
  
  movements         Movement[]
  audit_logs        AuditLog[]

  @@map("users")
}

model Movement {
  id                BigInt      @id @default(autoincrement())
  amount            Decimal     @db.Decimal(10, 2)
  type              String      // ingreso, egreso
  date              DateTime    @db.Date
  associated_to     String?     // collaborator/account name
  description       String      @db.Text
  status            String      @default("pendiente") // pendiente, completado
  
  user_id           BigInt
  user              User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updated_at

  @@map("movements")
}

model AuditLog {
  id                BigInt      @id @default(autoincrement())
  action            String      // created, updated, deleted
  model_type        String
  model_id          BigInt
  details           String      @db.Text
  
  user_id           BigInt
  user              User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updated_at

  @@map("audit_logs")
}
